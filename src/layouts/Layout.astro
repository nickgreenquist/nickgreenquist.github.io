---
import '../styles/global.css';
import { menuSectionLinks, menuBottomLinks, gatewayLinks } from '../data/links';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}

const {
  title = 'Nick Greenquist',
  description = 'Senior Software Engineer at Google working on Machine Learning and Recommendation Systems.',
  ogImage = '/me-og.jpg',
  ogType = 'website',
} = Astro.props;

const siteUrl = 'https://nickgreenquist.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const absoluteOgImage = new URL(ogImage, siteUrl).toString();

// JSON-LD Person schema (sitewide). `sameAs` profile URLs are derived from the
// single source of truth in src/data/links.ts so they can't drift.
const sameAsLabels = ['GitHub', 'LinkedIn', 'Instagram', 'Photography', 'Publications', 'Reading'];
const sameAs = sameAsLabels
  .map((label) => gatewayLinks.find((link) => link.label === label)?.href)
  .filter((href): href is string => Boolean(href));

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Nick Greenquist',
  url: `${siteUrl}/`,
  image: `${siteUrl}/me-og.jpg`,
  jobTitle: 'Senior Software Engineer',
  worksFor: { '@type': 'Organization', name: 'Google' },
  alumniOf: [
    { '@type': 'CollegeOrUniversity', name: 'New York University' },
    { '@type': 'CollegeOrUniversity', name: 'Rochester Institute of Technology' },
  ],
  knowsAbout: ['Machine Learning', 'Recommender Systems', 'Distributed Systems'],
  sameAs,
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />

		<!-- Resolve the theme before first paint to avoid a flash of the wrong theme. -->
		<script is:inline>
			(() => {
				const stored = localStorage.getItem('theme');
				const dark = stored
					? stored === 'dark'
					: window.matchMedia('(prefers-color-scheme: dark)').matches;
				document.documentElement.classList.toggle('dark', dark);
				// Mark the doc motion-ready only when JS runs AND motion is allowed,
				// so scroll-reveal elements start hidden from first paint (no flash)
				// while no-JS / reduced-motion visitors never get a hidden state.
				if (window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
					document.documentElement.classList.add('motion-ready');
				}
			})();
		</script>
		<meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#0c0c0e" media="(prefers-color-scheme: dark)" />

		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />

		<!--
			Favicons — generated by scripts/gen-favicons.mjs from the NG monogram.
			Modern browsers pick favicon.svg; legacy browsers fall back to favicon.ico;
			iOS uses apple-touch-icon; Android pulls icons from the web manifest.
			The ?v= query busts stale browser/CDN favicon caches — bump it (here and in
			the manifest's <link>) whenever the mark changes, to force a re-fetch.
		-->
		<link rel="icon" type="image/png" href="/favicon-96x96.png?v=2" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
		<link rel="shortcut icon" href="/favicon.ico?v=2" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=2" />
		<link rel="manifest" href="/site.webmanifest?v=2" />

		<!-- Feed autodiscovery -->
		<link rel="alternate" type="application/rss+xml" title="Nick Greenquist — Blog" href="/blog/feed.xml" />

		<!-- Open Graph -->
		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={absoluteOgImage} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content="Nick Greenquist" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={absoluteOgImage} />

		<!-- Structured data: Person (helps Google's Knowledge Graph) -->
		<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

		<!--
			GoatCounter analytics — privacy-friendly, cookieless, no sampling.
			PROD-only so dev page loads aren't counted.
		-->
		{
			import.meta.env.PROD && (
				<script
					is:inline
					data-goatcounter="https://nickgreenquist.goatcounter.com/count"
					async
					src="//gc.zgo.at/count.js"
				/>
			)
		}
	</head>
	<body class="bg-neutral-50 text-neutral-900 antialiased font-sans">
		<header id="top" class="sticky top-0 z-50 border-b border-neutral-200 bg-neutral-50/85 backdrop-blur">
			<div class="mx-auto max-w-3xl px-6 py-4 flex items-center justify-between gap-4">
				<a href="/" class="text-3xl sm:text-4xl font-bold tracking-tight text-neutral-900 hover:text-neutral-700 transition-colors">
					Nick Greenquist
				</a>
				<div class="flex items-center gap-1 sm:gap-2">
				<button
					id="theme-toggle"
					type="button"
					aria-label="Toggle dark mode"
					title="Toggle dark mode"
					class="flex h-9 w-9 cursor-pointer items-center justify-center rounded-md text-neutral-600 transition-colors hover:bg-neutral-100 hover:text-neutral-900"
				>
					<!-- Moon: shown in light mode (click → dark) -->
					<svg class="h-5 w-5 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
					</svg>
					<!-- Sun: shown in dark mode (click → light) -->
					<svg class="hidden h-5 w-5 dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<circle cx="12" cy="12" r="4" />
						<path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
					</svg>
				</button>
				<details data-menu class="group relative">
					<summary aria-label="Open links menu" class="flex cursor-pointer list-none select-none items-center text-neutral-600 transition-colors hover:text-neutral-900 [&::-webkit-details-marker]:hidden">
						<svg class="h-8 w-10 sm:h-9 sm:w-11" viewBox="0 0 30 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
							<line x1="3" y1="6" x2="27" y2="6" />
							<line x1="3" y1="12" x2="27" y2="12" />
							<line x1="3" y1="18" x2="27" y2="18" />
						</svg>
					</summary>
					<nav class="absolute right-0 mt-2 flex w-48 flex-col rounded-lg border border-neutral-200 bg-white p-2 text-sm shadow-lg">
						{
							menuSectionLinks.map((link) => (
								<a
									href={link.href}
									target={link.external ? '_blank' : undefined}
									rel={link.external ? 'noopener noreferrer' : undefined}
									class="rounded-md px-3 py-2 text-neutral-700 transition-colors hover:bg-neutral-100 hover:text-neutral-900"
								>
									{link.label}
								</a>
							))
						}
						<hr class="my-1 border-neutral-200" />
						{
							menuBottomLinks.map((link) => (
								<a
									href={link.href}
									target={link.external ? '_blank' : undefined}
									rel={link.external ? 'noopener noreferrer' : undefined}
									class="rounded-md px-3 py-2 text-neutral-700 transition-colors hover:bg-neutral-100 hover:text-neutral-900"
								>
									{link.label}
								</a>
							))
						}
					</nav>
				</details>
				</div>
			</header>
		<slot />
		<footer class="mx-auto max-w-3xl px-6 py-12 flex justify-center text-sm text-neutral-500">
			<a
				href="#top"
				data-back-to-top
				class="inline-flex items-center gap-1.5 rounded-full border border-neutral-200 px-4 py-2 font-medium transition-colors hover:border-neutral-900 hover:text-neutral-900"
			>
				<span aria-hidden="true">↑</span>
				Back to top
			</a>
		</footer>
		<script>
			const menus = document.querySelectorAll('details[data-menu]');
			document.addEventListener('click', (event) => {
				menus.forEach((menu) => {
					if (menu.hasAttribute('open') && !menu.contains(event.target as Node)) {
						menu.removeAttribute('open');
					}
				});
			});
			document.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') {
					menus.forEach((menu) => menu.removeAttribute('open'));
				}
			});
			document.querySelector('[data-back-to-top]')?.addEventListener('click', (event) => {
				event.preventDefault();
				window.scrollTo({ top: 0, behavior: 'smooth' });
			});

			// Theme toggle. The new theme is revealed in a circle growing from the
			// click point via the View Transitions API; reduced-motion users and
			// browsers without it get an instant swap. (The pre-paint script in
			// <head> sets the initial class so there's no flash on load.)
			const root = document.documentElement;
			const themeToggle = document.getElementById('theme-toggle');
			themeToggle?.addEventListener('click', (event) => {
				const next = root.classList.contains('dark') ? 'light' : 'dark';
				const apply = () => {
					root.classList.toggle('dark', next === 'dark');
					localStorage.setItem('theme', next);
				};
				const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
				if (!document.startViewTransition || reduce) {
					apply();
					return;
				}
				const rect = themeToggle.getBoundingClientRect();
				const x = event.clientX || rect.left + rect.width / 2;
				const y = event.clientY || rect.top + rect.height / 2;
				const r = Math.hypot(
					Math.max(x, window.innerWidth - x),
					Math.max(y, window.innerHeight - y),
				);
				root.style.setProperty('--theme-x', `${x}px`);
				root.style.setProperty('--theme-y', `${y}px`);
				root.style.setProperty('--theme-r', `${r}px`);
				document.startViewTransition(apply);
			});

			// Scroll-reveal: reveal each [data-reveal] once as it enters the viewport.
			// Only runs when motion-ready (JS + motion allowed); otherwise the CSS
			// never hid them. Falls back to revealing all if IntersectionObserver
			// is unavailable, so nothing can stay stuck invisible.
			if (root.classList.contains('motion-ready')) {
				const revealEls = document.querySelectorAll('[data-reveal]');
				if ('IntersectionObserver' in window) {
					const io = new IntersectionObserver((entries, observer) => {
						for (const entry of entries) {
							if (entry.isIntersecting) {
								entry.target.classList.add('is-visible');
								observer.unobserve(entry.target);
							}
						}
					}, { rootMargin: '0px 0px -8% 0px' });
					revealEls.forEach((el) => io.observe(el));
				} else {
					revealEls.forEach((el) => el.classList.add('is-visible'));
				}
			}
		</script>
	</body>
</html>
