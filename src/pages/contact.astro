---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact · Nick Greenquist"
  description="Get in touch — ML engineering, career opportunities, research, photography, or anything else."
>
  <main class="mx-auto max-w-3xl px-6 py-16">
    <header class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">Contact</h1>
      <p class="mt-2 text-neutral-600">
        Happy to hear from you — ML engineering, career opportunities, research, photography, or anything else. I try to reply within a few days.
      </p>
    </header>

    <div class="rounded-lg border border-neutral-200 bg-white p-5">
      <form
        action="https://formspree.io/f/maqvayqy"
        method="POST"
        class="space-y-4"
      >
        <div>
          <label for="name" class="block text-sm font-medium text-neutral-700 mb-1">Name</label>
          <input
            type="text"
            name="name"
            id="name"
            required
            class="w-full rounded-md border border-neutral-300 px-3 py-2 text-neutral-900 focus:border-neutral-900 focus:outline-none focus:ring-1 focus:ring-neutral-900"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-neutral-700 mb-1">Email</label>
          <input
            type="email"
            name="email"
            id="email"
            required
            class="w-full rounded-md border border-neutral-300 px-3 py-2 text-neutral-900 focus:border-neutral-900 focus:outline-none focus:ring-1 focus:ring-neutral-900"
          />
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-neutral-700 mb-1">Message</label>
          <textarea
            name="message"
            id="message"
            rows="6"
            required
            class="w-full rounded-md border border-neutral-300 px-3 py-2 text-neutral-900 focus:border-neutral-900 focus:outline-none focus:ring-1 focus:ring-neutral-900"
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full rounded-md bg-neutral-900 px-4 py-2 text-neutral-50 font-medium hover:bg-neutral-700 transition-colors"
        >
          Send
        </button>
      </form>
      <p class="mt-4 text-sm text-neutral-500">
        Prefer email? <a href="mailto:nickgreenquist@gmail.com" class="underline hover:text-neutral-900">nickgreenquist@gmail.com</a>
      </p>
    </div>
  </main>
</Layout>
