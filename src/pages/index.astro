---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import GatewayCard from '../components/GatewayCard.astro';
import RecommenderCard from '../components/RecommenderCard.astro';
import JourneyTimeline from '../components/JourneyTimeline.astro';
import PhotoGrid from '../components/PhotoGrid.astro';
import { headline, subhead, bioIntro, journeyLead, journey } from '../data/about';
import { photos, portfolioUrl } from '../data/photography';
import { gatewayLinks } from '../data/links';
import { postPath, formatDate, byNewest, categoryLabel } from '../utils/blog';
import mePhoto from '../assets/me.jpg';

import { movie, book, steam, amazon } from '../data/projects';

// Featured posts: those with a `pinned` number in frontmatter, ordered by it
// (lower first). Falls back to the latest 3 if nothing is pinned yet.
const allPosts = (await getCollection('blog')).sort(byNewest);
const pinned = allPosts
  .filter((post) => post.data.pinned != null)
  .sort((a, b) => a.data.pinned! - b.data.pinned!);
const featuredPosts = pinned.length > 0 ? pinned : allPosts.slice(0, 3);
---

<Layout
  title="Nick Greenquist"
  description="Senior Software Engineer at Google. Machine Learning and Recommendation Systems."
>
  <main class="mx-auto max-w-3xl px-6 py-10 sm:py-16">
    <!-- Hero -->
    <section class="flex flex-col sm:flex-row items-start gap-8">
      <div class="space-y-3 flex-1">
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight">{headline}</h1>
        <p class="text-lg sm:text-xl text-neutral-600">{subhead}</p>
      </div>
      <Image
        src={mePhoto}
        alt="Nick Greenquist"
        widths={[128, 192, 256]}
        sizes="128px"
        class="w-36 sm:w-36 rounded-2xl flex-shrink-0 sm:self-auto self-center"
        loading="eager"
      />
    </section>

    <!-- About -->
    <section data-reveal class="mt-10 space-y-4 text-neutral-700 leading-relaxed">
      <p set:html={bioIntro} class="[&_a]:underline [&_a]:decoration-neutral-400 [&_a]:underline-offset-2 [&_a:hover]:text-neutral-950 [&_a:hover]:decoration-neutral-900"></p>
      <p>{journeyLead}</p>
      <div class="py-2">
        <JourneyTimeline steps={journey} />
      </div>
    </section>

    <!-- At the Keyboard -->
    <section data-reveal class="mt-10">
      <div class="flex items-center justify-between gap-4 mb-1">
        <h2 class="text-lg font-semibold uppercase tracking-wider text-neutral-500">At the Keyboard</h2>
        <a href="/projects" class="group flex flex-shrink-0 items-center gap-1 text-base font-medium text-neutral-500 transition-colors hover:text-neutral-900">
          Full deep-dive
          <span class="transition-transform group-hover:translate-x-0.5">→</span>
        </a>
      </div>
      <p class="text-neutral-500 mb-4">Production-grade recommender systems: built in PyTorch and deployed live on Streamlit.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {[movie, book, steam, amazon].map((r) => (
          <RecommenderCard emoji={r.emoji} shortLabel={r.shortLabel} arch={r.arch} demoHref={r.demoHref} />
        ))}
      </div>
    </section>

    <!-- From the Blog -->
    <section data-reveal class="mt-10">
      <div class="flex items-center justify-between gap-4 mb-4">
        <h2 class="text-lg font-semibold uppercase tracking-wider text-neutral-500">Featured Blog Posts</h2>
        <a href="/blog" class="group flex flex-shrink-0 items-center gap-1 text-base font-medium text-neutral-500 transition-colors hover:text-neutral-900">
          See all posts
          <span class="transition-transform group-hover:translate-x-0.5">→</span>
        </a>
      </div>
      <div class="grid grid-cols-1 gap-3">
        {featuredPosts.map((post) => (
          <a
            href={postPath(post)}
            class="group block rounded-lg border border-neutral-200 bg-white p-5 transition-all duration-200 ease-spring hover:border-neutral-900 hover:shadow-lg motion-safe:hover:-translate-y-1"
          >
            <div class="flex items-center gap-3 text-sm text-neutral-500">
              <time datetime={post.data.date}>{formatDate(post.data.date)}</time>
              <span class="inline-block rounded-full bg-neutral-100 px-2.5 py-0.5 text-xs font-medium text-neutral-600">
                {categoryLabel(post.data.category)}
              </span>
            </div>
            <div class="mt-1.5 flex items-center justify-between gap-3">
              <h3 class="font-semibold text-neutral-900">{post.data.title}</h3>
              <span class="flex-shrink-0 text-neutral-400 transition-all group-hover:translate-x-0.5 group-hover:text-neutral-900">→</span>
            </div>
            {post.data.description && (
              <p class="mt-1 text-sm text-neutral-600">{post.data.description}</p>
            )}
          </a>
        ))}
      </div>
    </section>

    <!-- Publications -->
    <section data-reveal id="publications" class="mt-10 scroll-mt-20">
      <div class="flex items-center justify-between gap-4 mb-1">
        <h2 class="text-lg font-semibold uppercase tracking-wider text-neutral-500">Publications</h2>
        <a href="https://scholar.google.com/citations?user=28QAvAcAAAAJ&hl=en" target="_blank" rel="noopener noreferrer" class="group flex flex-shrink-0 items-center gap-1 text-base font-medium text-neutral-500 transition-colors hover:text-neutral-900">
          See all publications
          <span class="transition-transform group-hover:translate-x-0.5">→</span>
        </a>
      </div>
      <p class="text-neutral-500 mb-4">Peer-reviewed research in recommendation systems.</p>
      <div class="grid grid-cols-1 gap-3">
        <GatewayCard
          href="https://link.springer.com/chapter/10.1007/978-3-031-36625-3_12"
          label="Pyrorank: A Novel Nature-Inspired Algorithm to Promote Diversity in Recommender Systems"
          description="Doruk Kilitcioglu, Nicholas Greenquist & Anasse Bari · ICSI 2023 · Jul 2023"
          external
        />
        <GatewayCard
          href="https://ieeexplore.ieee.org/abstract/document/9403110"
          label="GPU Accelerated Matrix Factorization for Recommender Systems"
          description="Doruk Kilitcioglu, Nicholas Greenquist, Mohamed Zahran & Anasse Bari · ICBDA · Apr 2021"
          external
        />
        <GatewayCard
          href="https://ieeexplore.ieee.org/document/8713194"
          label="GKB: A Predictive Analytics Framework to Generate Online Product Recommendations"
          description="Nicholas Greenquist, Doruk Kilitcioglu & Anasse Bari · ICBDA · Mar 2019"
          external
        />
      </div>
    </section>

    <!-- Through the Lens -->
    <section data-reveal class="mt-10">
      <div class="flex items-center justify-between gap-4 mb-1">
        <h2 class="text-lg font-semibold uppercase tracking-wider text-neutral-500">Photography</h2>
        <a href={portfolioUrl} target="_blank" rel="noopener noreferrer" class="group flex flex-shrink-0 items-center gap-1 text-base font-medium text-neutral-500 transition-colors hover:text-neutral-900">
          See full portfolio
          <span class="transition-transform group-hover:translate-x-0.5">→</span>
        </a>
      </div>
      <p class="text-neutral-500 mb-4">Whenever I have a free moment I'm out with my camera. A few favorites gallery links below.</p>
      <PhotoGrid photos={photos} />

      <!-- Recognition -->
      <div class="mt-8">
        <h3 class="text-sm font-semibold uppercase tracking-wider text-neutral-500 mb-3">Recognition</h3>
        <div class="grid grid-cols-1 gap-3">
          <GatewayCard
            href="https://g1.globo.com/ms/mato-grosso-do-sul/noticia/2022/01/13/norte-americano-conhece-pantanal-e-registra-flagrantes-exclusivos-da-fauna-pantaneira-veja-fotos.ghtml"
            label="G1 (Globo) — Featured Story"
            description="Featured for wildlife photography from the Pantanal, Brazil (2022)."
            external
          />
          <GatewayCard
            href="https://njmonthly.com/articles/arts-entertainment/the-winners-of-new-jersey-monthly-and-unique-photos-2025-cover-search-contest/"
            label="New Jersey Monthly — Magazine Cover Search Competition"
            description="Honorable Mention for 'New Residents of Cape May,' selected from 1,509 submissions (2025)."
            external
          />
          <GatewayCard
            href="https://www.newjerseystage.com/articles/getarticle2.php?titlelink=the-atlantic-highlands-arts-council-presents-black-and-white-and-monochrome"
            label="Atlantic Highlands Arts Council — Juried Gallery"
            description="Piece selected for the 'Black & White & Monochrome' juried exhibition and sold (2022)."
            external
          />
        </div>
      </div>
    </section>

    <!-- Away from the Keyboard -->
    <section data-reveal id="away-from-the-keyboard" class="mt-10 scroll-mt-20">
      <h2 class="text-lg font-semibold uppercase tracking-wider text-neutral-500 mb-1">Away from the Keyboard</h2>
      <p class="text-neutral-500 mb-4">Reading, fitness, travel and above all: being a dad.</p>
      <div class="space-y-4 text-neutral-700 leading-relaxed [&_a]:underline [&_a]:decoration-neutral-400 [&_a]:underline-offset-2 [&_a:hover]:text-neutral-950 [&_a:hover]:decoration-neutral-900">
        <p><strong >New Dad</strong>: I became a dad this past year. It is easily the most important thing that's happened in my life. Most of my time and energy these days goes into being the best father I can be.</p>
        <p><strong >Travel</strong>: We've kept traveling even as new parents (at least trying to). Our son has already been to Cancun, Mexico and to Campo Grande, Brazil for his first birthday and to meet his Brazilian family. Next up is a summer camping trip with our trailer. I keep my travel map up to date <a href="/map">here</a>.</p>
        <p><strong >Fitness</strong>: Old habits from wrestling die hard; physical fitness is still an important part of my routine, and the best way I know to clear my head. I lift weights 5-6x a week and try to walk 10k+ steps a day.</p>
        <p><strong >Books</strong>: I'm always reading or listening to audiobooks. Check out my <a href="https://www.goodreads.com/user/show/26809953-nick-greenquist" target="_blank" rel="noopener noreferrer">Goodreads</a> to see what I've recently finished and what I'm currently reading.</p>
        <p><strong >Pokémon</strong>: Having a kid sent me straight back to my childhood: I've gotten back into collecting Pokémon cards with the hope of passing the hobby on to my son when he's ready. My goal is to complete the Pokédex (one card for every one of the 1000+ Pokémon) and you can follow my progress in <a href="https://docs.google.com/spreadsheets/d/1FStZBCxWdJ_uC8c_WV24eZsVzI-EmIZHouPKxaG6pcY/edit?usp=sharing" target="_blank" rel="noopener noreferrer">this live tracker</a>.</p>
      </div>
    </section>

    <!-- Gateway grid -->
    <section data-reveal class="mt-12">
      <h2 class="text-lg font-semibold uppercase tracking-wider text-neutral-500 mb-4">Links</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {
          gatewayLinks.map((link) => (
            <GatewayCard
              href={link.href}
              label={link.label}
              description={link.description}
              external={link.external}
            />
          ))
        }
      </div>
    </section>
  </main>
</Layout>
