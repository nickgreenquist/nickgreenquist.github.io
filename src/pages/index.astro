---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import GatewayCard from '../components/GatewayCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { headline, subhead, bioParagraphs } from '../data/about';
import mePhoto from '../assets/me.jpg';
---

<Layout
  title="Nick Greenquist"
  description="Senior Software Engineer at Google. Machine Learning and Recommendation Systems."
>
  <main class="mx-auto max-w-3xl px-6 py-10 sm:py-16">
    <!-- Hero -->
    <section class="flex flex-col sm:flex-row items-start gap-8">
      <div class="space-y-3 flex-1">
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight">{headline}</h1>
        <p class="text-lg sm:text-xl text-neutral-600">{subhead}</p>
      </div>
      <Image
        src={mePhoto}
        alt="Nick Greenquist"
        widths={[128, 192, 256]}
        sizes="128px"
        class="w-36 sm:w-36 rounded-2xl flex-shrink-0 sm:self-auto self-center"
        loading="eager"
      />
    </section>

    <!-- About -->
    <section class="mt-10 space-y-4 text-neutral-700 leading-relaxed">
      {bioParagraphs.map((p) => (
        <p set:html={p} class="[&_a]:underline [&_a]:decoration-neutral-400 [&_a]:underline-offset-2 [&_a:hover]:text-neutral-950 [&_a:hover]:decoration-neutral-900"></p>
      ))}
    </section>

    <!-- At the Keyboard -->
    <section class="mt-10">
      <h2 class="text-lg font-semibold uppercase tracking-wider text-neutral-500 mb-1">At the Keyboard</h2>
      <p class="text-sm text-neutral-500 mb-4">What I'm currently building.</p>
      <p class="text-neutral-700 leading-relaxed mb-4">A series of state-of-the-art two-tower neural recommenders built with PyTorch. Each model learns separate user and item embeddings from interaction history and content features, trained with full softmax and A. Menon popularity debiasing so results reflect genuine taste — not just what's trending. No account needed.</p>
      <p class="text-sm text-neutral-500 mb-4">Note: These demos run on Streamlit's free tier and sleep after a few hours of inactivity. If you land on a "Wake up" screen, just click the button — the app will be ready in about 15–30 seconds.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <ProjectCard
          label="Movie Recommender"
          dataset="MovieLens 32M Dataset"
          items="9,375 movies"
          users="~50k users"
          demoHref="https://movie-recommender-system-two-tower-model.streamlit.app/"
        />
        <ProjectCard
          label="Book Recommender"
          dataset="Goodreads Dataset"
          items="14,753 books"
          users="229k users"
          demoHref="https://book-recommender-system-two-tower-model.streamlit.app/"
        />
        <ProjectCard
          label="Game Recommender"
          dataset="Steam Dataset"
          items="5,437 games"
          users="66k users"
          demoHref="https://game-recommender-system-two-tower-model.streamlit.app/"
        />
      </div>
      <p class="mt-3 text-sm text-neutral-500">
        Source:
        <a href="https://github.com/nickgreenquist/Movie-Recommender-System-PyTorch-TwoTower-Model" target="_blank" rel="noopener noreferrer" class="hover:text-neutral-900 hover:underline">Movies ↗</a>
        ·
        <a href="https://github.com/nickgreenquist/Book-Recommender-System-PyTorch-TwoTower-Model" target="_blank" rel="noopener noreferrer" class="hover:text-neutral-900 hover:underline">Books ↗</a>
        ·
        <a href="https://github.com/nickgreenquist/Game-Recommender-System-PyTorch-TwoTower-Model" target="_blank" rel="noopener noreferrer" class="hover:text-neutral-900 hover:underline">Games ↗</a>
      </p>
    </section>

    <!-- Publications -->
    <section class="mt-10">
      <h2 class="text-lg font-semibold uppercase tracking-wider text-neutral-500 mb-4">Publications</h2>
      <div class="grid grid-cols-1 gap-3">
        <GatewayCard
          href="https://link.springer.com/chapter/10.1007/978-3-031-36625-3_12"
          label="Pyrorank: A Novel Nature-Inspired Algorithm to Promote Diversity in Recommender Systems"
          description="Doruk Kilitcioglu, Nicholas Greenquist & Anasse Bari · ICSI 2023 · Jul 2023"
          external
        />
        <GatewayCard
          href="https://ieeexplore.ieee.org/abstract/document/9403110"
          label="GPU Accelerated Matrix Factorization for Recommender Systems"
          description="Doruk Kilitcioglu, Nicholas Greenquist, Mohamed Zahran & Anasse Bari · ICBDA · Apr 2021"
          external
        />
        <GatewayCard
          href="https://ieeexplore.ieee.org/document/8713194"
          label="GKB: A Predictive Analytics Framework to Generate Online Product Recommendations"
          description="Nicholas Greenquist, Doruk Kilitcioglu & Anasse Bari · ICBDA · Mar 2019"
          external
        />
      </div>
    </section>

    <!-- Away from the Keyboard -->
    <section class="mt-10">
      <h2 class="text-lg font-semibold uppercase tracking-wider text-neutral-500 mb-1">Away from the Keyboard</h2>
      <p class="text-sm text-neutral-500 mb-4">What's keeping me busy in the real world.</p>
      <div class="space-y-4 text-neutral-700 leading-relaxed [&_a]:underline [&_a]:decoration-neutral-400 [&_a]:underline-offset-2 [&_a:hover]:text-neutral-950 [&_a:hover]:decoration-neutral-900">
        <p><strong >New Dad</strong> — I became a dad this past year — easily the most important thing that's happened in my life. Most of my time and energy these days goes into being the best father I can be.</p>
        <p><strong >Photography</strong> — Whenever I have a free moment I'm out with my camera. Best work lives on my <a href="https://nickgreenquist.myportfolio.com/" target="_blank" rel="noopener noreferrer">portfolio</a>; I also post more frequently to <a href="https://www.instagram.com/nickgreenquist/" target="_blank" rel="noopener noreferrer">Instagram</a>.</p>
        <p><strong >Travel</strong> — We've kept traveling even as new parents — our son has already been to Cancun, Mexico and to Campo Grande, Brazil for his first birthday and to meet his Brazilian family. Next up is a summer camping trip with our towable trailer.</p>
        <p><strong >Books</strong> — I'm always reading or listening to audiobooks. Check out my <a href="https://www.goodreads.com/user/show/26809953-nick-greenquist" target="_blank" rel="noopener noreferrer">Goodreads</a> to see what I've recently finished and what I'm currently reading — I keep it up to date.</p>
        <p><strong >Pokémon</strong> — Having a kid sent me straight back to my childhood: I've gotten back into collecting Pokémon cards with the hope of passing the hobby on to my son when he's ready. My goal is to complete the Pokédex — one card for every one of the 1000+ Pokémon.</p>
      </div>
    </section>

    <!-- Gateway grid -->
    <section class="mt-12">
      <h2 class="text-lg font-semibold uppercase tracking-wider text-neutral-500 mb-4">Links</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <GatewayCard
          href="https://github.com/nickgreenquist"
          label="GitHub"
          description="Personal projects — recommender systems and ML."
          external
        />
        <GatewayCard
          href="https://www.linkedin.com/in/nickgreenquist/"
          label="LinkedIn"
          description="Professional and career details."
          external
        />
        <GatewayCard
          href="https://nickgreenquist.myportfolio.com/"
          label="Photography"
          description="Wildlife and travel photography portfolio."
          external
        />
        <GatewayCard
          href="https://nickgreenquist.github.io/blog/"
          label="Blog"
          description="Thoughts on machine learning, systems, and projects."
          external
        />
        <GatewayCard
          href="/map"
          label="Travel Map"
          description="Everywhere I've been on Earth. (under construction)"
        />
        <GatewayCard
          href="/wrestling"
          label="Wrestling"
          description="What it took, what it gave back."
        />
        <GatewayCard
          href="/education"
          label="Education"
          description="Every course I've taken — NYU, RIT, and online."
        />
        <GatewayCard
          href="/Resume.pdf"
          label="Resume"
          description="PDF, kept current."
          external
        />
        <GatewayCard
          href="https://www.goodreads.com/user/show/26809953-nick-greenquist"
          label="Reading"
          description="My reading list on Goodreads"
          external
        />
        <GatewayCard
          href="/contact"
          label="Contact"
          description="Send me a message."
        />
      </div>
    </section>
  </main>
</Layout>
