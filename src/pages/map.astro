---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Travel Map · Nick Greenquist"
  description="Places I've lived, visited, and want to return to."
>
  <main class="mx-auto max-w-7xl px-6 py-16">
    <header class="mb-6 max-w-4xl">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">Oh, the places you'll go</h1>
      <p class="mt-2 text-neutral-600">Every place I've been on Earth. Still filling this in — more pins coming.</p>
    </header>

    <div class="w-full overflow-hidden rounded-lg border border-neutral-200 bg-white aspect-[2/3] sm:aspect-video">
      <iframe
        src="https://www.google.com/maps/d/u/0/embed?mid=1SGBSxjz3azsfBz95mCXOsjUkdLXJnMk&ehbc=2E312F"
        class="h-full w-full border-0"
        allowfullscreen
        loading="lazy"
        title="Nick Greenquist travel map"
      ></iframe>
    </div>
  </main>
</Layout>
