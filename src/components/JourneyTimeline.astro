---
import type { JourneyStep } from '../data/about';

interface Props {
  steps: JourneyStep[];
}

const { steps } = Astro.props;
const last = steps.length - 1;
---

<ol class="relative space-y-8">
  <span
    class="absolute left-8 top-4 bottom-4 w-0.5 -ml-px bg-gradient-to-b from-neutral-200 via-neutral-300 to-neutral-900"
    aria-hidden="true"></span>
  {steps.map((step, i) => {
    const NodeTag = step.href ? 'a' : 'span';
    return (
    <li class="group relative flex gap-5 sm:gap-6">
      <NodeTag
        href={step.href}
        target={step.href ? '_blank' : undefined}
        rel={step.href ? 'noopener noreferrer' : undefined}
        aria-label={step.href ? step.title : undefined}
        class:list={[
          // The nodes are logo chips — several logos are designed for a light
          // background (NYU, the lifeguard mark), so the circles stay white in
          // BOTH themes. Colors are literal hex (not neutral-* utilities) so they
          // don't theme-flip; overflow-hidden clips each logo to the circle.
          'z-10 flex h-16 w-16 shrink-0 items-center justify-center overflow-hidden rounded-full border bg-[#fff] shadow-sm transition-all group-hover:scale-110 group-hover:border-[#171717]',
          i === last ? 'border-[#171717] ring-4 ring-[#171717]/10' : 'border-[#e5e5e5]',
        ]}
      >
        {step.logo ? (
          <img
            src={step.logo.src}
            alt=""
            width={step.logo.width}
            height={step.logo.height}
            class:list={[
              'object-contain',
              step.logoWidth ?? (step.logo.width / step.logo.height > 1.5 ? 'w-[76%]' : 'w-[56%]'),
            ]}
          />
        ) : (
          <span class="text-3xl leading-none">{step.icon}</span>
        )}
      </NodeTag>
      <div class="pt-1.5">
        <div class="text-xs font-semibold uppercase tracking-wider text-neutral-400">{step.years}</div>
        <div class="font-semibold text-neutral-900 leading-snug">{step.title}</div>
        <p
          set:html={step.blurb}
          class="mt-0.5 text-sm text-neutral-600 leading-relaxed [&_a]:underline [&_a]:decoration-neutral-400 [&_a]:underline-offset-2 [&_a:hover]:text-neutral-950 [&_a:hover]:decoration-neutral-900"
        ></p>
      </div>
    </li>
    );
  })}
</ol>
