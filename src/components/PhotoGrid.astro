---
import { Image } from 'astro:assets';
import type { Photo } from '../data/photography';

interface Props {
  photos: Photo[];
}

const { photos } = Astro.props;
---

<div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
  {photos.map((photo) => (
    <a
      href={photo.href}
      target="_blank"
      rel="noopener noreferrer"
      class="group relative block aspect-square overflow-hidden rounded-lg border border-neutral-200 transition-all hover:border-neutral-900 hover:shadow-md"
    >
      <Image
        src={photo.image}
        alt={`${photo.label} — photo by Nick Greenquist`}
        widths={[300, 600, 900]}
        sizes="(max-width: 640px) 50vw, 235px"
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        loading="lazy"
      />
      <span class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/60 to-transparent px-3 pb-2 pt-8 text-sm font-medium text-white">
        {photo.label}
      </span>
    </a>
  ))}
</div>
