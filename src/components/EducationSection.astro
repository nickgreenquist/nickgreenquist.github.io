---
import coursesData from '../data/courses.json';

const { sections } = coursesData;
---

<section class="space-y-3">
  {sections.map((section) => (
    <details class="group rounded-lg border border-neutral-200 bg-white">
      <summary class="cursor-pointer list-none px-5 py-3 flex items-center justify-between gap-4 font-medium text-sm text-neutral-900 hover:bg-neutral-50 rounded-lg">
        <span>{section.section}</span>
        <span class="flex items-center gap-3 text-xs text-neutral-500 shrink-0">
          <span>{section.courses.length} {section.courses.length === 1 ? 'course' : 'courses'}</span>
          <span class="transition-transform group-open:rotate-90">›</span>
        </span>
      </summary>
      <ul class="border-t border-neutral-200 divide-y divide-neutral-100">
        {section.courses.map((course) => (
          <li class="px-5 py-3">
            <details class="group/inner">
              <summary class="cursor-pointer list-none font-medium text-sm text-neutral-800 hover:text-neutral-950 flex items-start gap-2 flex-wrap">
                <span class="flex items-start gap-1.5 flex-1">
                  <span class="text-neutral-400 transition-transform group-open/inner:rotate-90 text-xs mt-0.5 shrink-0">›</span>
                  <span>{course.title}</span>
                </span>
                {course.provider && (
                  <a
                    href={course.provider.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    onclick="event.stopPropagation()"
                    class="ml-1 inline-flex items-center gap-1 rounded-full border border-neutral-200 px-2 py-0.5 text-xs font-normal text-neutral-600 hover:border-neutral-900 hover:text-neutral-900"
                  >
                    {course.provider.name}
                    <span aria-hidden="true">↗</span>
                  </a>
                )}
              </summary>
              {course.description && (
                <p
                  class="mt-2 ml-5 text-sm text-neutral-600 leading-relaxed [&_a]:underline [&_a]:decoration-neutral-400 [&_a]:underline-offset-2 hover:[&_a]:text-neutral-950"
                  set:html={course.description}
                ></p>
              )}
            </details>
          </li>
        ))}
      </ul>
    </details>
  ))}
</section>
