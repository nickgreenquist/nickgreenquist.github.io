---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Photo {
  src: ImageMetadata;
  alt: string;
  caption: string;
}

interface Props {
  photos: Photo[];
}

const { photos } = Astro.props;
---

<div class="my-10 grid grid-cols-1 sm:grid-cols-3 gap-4">
  {photos.map((photo) => (
    <figure class="overflow-hidden rounded-lg border border-neutral-200 bg-white">
      <Image
        src={photo.src}
        alt={photo.alt}
        widths={[300, 600, 900]}
        sizes="(max-width: 640px) 100vw, 33vw"
        class="w-full h-56 object-cover"
        loading="lazy"
      />
      <figcaption class="px-3 py-2 text-xs text-neutral-500">
        {photo.caption}
      </figcaption>
    </figure>
  ))}
</div>
